style.
  body {
    background-color: #f5f7f3;
    color: #243429;
    font-family: Georgia, "Times New Roman", serif;
    -webkit-font-smoothing: antialiased;
    margin: 0;
    padding: 0;
  }
  table {
    border-collapse: separate;
    width: 100%;
  }
  table td {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 15px;
    line-height: 1.6;
    vertical-align: top;
  }
  .body {
    background-color: #f5f7f3;
    width: 100%;
  }
  .container {
    margin: 0 auto !important;
    max-width: 620px;
    padding: 24px 12px;
    width: 620px;
  }
  .content {
    margin: 0 auto;
    max-width: 620px;
  }
  .main {
    background: #ffffff;
    border: 1px solid #d9e5dc;
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
  }
  .brand-header {
    background: #0ca678;
    color: #ffffff;
    padding: 18px 24px;
    text-align: center;
  }
  .brand-kicker {
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }
  .wrapper {
    padding: 24px;
  }
  p {
    color: #243429;
    font-size: 15px;
    margin: 0 0 14px;
  }
  a {
    color: #0b7d5d;
    text-decoration: underline;
  }
  .btn a {
    background-color: #0ca678;
    border: 1px solid #0ca678;
    border-radius: 6px;
    color: #ffffff !important;
    display: inline-block;
    font-size: 14px;
    font-weight: 700;
    padding: 11px 22px;
    text-decoration: none;
  }
  .message-box {
    background: #f6fbf8;
    border: 1px solid #d9e5dc;
    border-radius: 10px;
    padding: 14px;
    white-space: pre-wrap;
  }
  .footer {
    margin-top: 10px;
    text-align: center;
  }
  .footer td,
  .footer p,
  .footer span,
  .footer a {
    color: #6d7f73;
    font-size: 12px;
    text-align: center;
  }
  .preheader {
    color: transparent;
    display: none;
    height: 0;
    max-height: 0;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    visibility: hidden;
    width: 0;
  }
  @media only screen and (max-width: 620px) {
    .container {
      padding: 0 !important;
      width: 100% !important;
    }
    .main {
      border-left-width: 0 !important;
      border-radius: 0 !important;
      border-right-width: 0 !important;
    }
    .wrapper {
      padding: 18px !important;
    }
    table[class=body] td,
    table[class=body] p,
    table[class=body] a,
    table[class=body] span {
      font-size: 15px !important;
    }
  }