extends baseEmail

block content
  p Hello #{firstName},
  p
    | We received a request to reset the password for your #{companyName} account.
    | Use the link below to choose a new password. It expires in one hour.
  table.btn.btn-primary(role='presentation' border='0' cellpadding='0' cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation' border='0' cellpadding='0' cellspacing='0')
            tbody
              tr
                td
                  a(href=resetUrl) Reset password
  p(style='font-size: 14px; color: #666; word-break: break-all;')
    | If the button does not work, copy and paste this URL into your browser:
    br
    | #{resetUrl}
  p If you did not request a password reset, you can ignore this email.
